            result = { type: 'complex', ai: 'dola', content };
        } else {
            toolUsed = 'Mistral AI (Shop simple)';
            const content = await callMistralJSON(
                `Génère un contenu simple pour ${type} en JSON:
                {
                    "titre": "Titre",
                    "description": "Description courte",
                    "prix": "Prix indicatif"
                }`,
                `Brief: ${brief}`
            );
            const canvaUrl = generateCanvaAutofill(process.env.CANVA_TEMPLATE_LOGO || 'DAFxxxxx', {
                'nom_client': clientName,
                'nom_entreprise': entreprise || '718Digital',
                ...content
            });
            result = { type: 'simple', ai: 'mistral', url: canvaUrl, content };
        }

        if (process.env.AIRTABLE_API_KEY && projectId) {
            await updateRecord('Projets', projectId, {
                'Statut': 'Shop Prêt',
                'Outil Utilisé': toolUsed,
                'Lien Livrable': result.url || JSON.stringify(result.content)
