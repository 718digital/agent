// =============================================
// AGENT 00 - ACCUEIL CLIENT (Mistral)
// =============================================
app.post('/webhook/agent-00', async (req, res) => {
    try {
        const { from, message } = req.body;
        console.log(`📩 [Agent 00 - Mistral] ${from}: ${message}`);

        const aiResponse = await callMistral(PROMPTS.AGENT_00, message);

        const scoreMatch = aiResponse.match(/Score[: ]+(\d+)/i);
        const score = scoreMatch ? parseInt(scoreMatch[1]) : 5;

        let prospectId = null;
        if (process.env.AIRTABLE_API_KEY) {
            const prospect = await createRecord('Prospects', {
                'Téléphone': from,
                'Dernier Message': message,
                'Score': score,
                'Statut': score >= 7 ? 'Qualifié' : 'Nurturing',
                'Date Contact': new Date().toISOString()
            });
            prospectId = prospect.id;
        }

        await sendWhatsApp(from, aiResponse);

        if (score >= 7) {
            await sendWhatsApp(from,
                `🎯 Excellent ! Remplissez notre formulaire de brief :\n📝 https://votre-typeform.com/brief\n\nUn expert vous recontactera sous 24h.`
            );
        }

        res.json({ status: 'success', score, prospectId });

    } catch (error) {
        console.error('❌ Agent 00 Error:', error);
        res.status(500).json({ status: 'error', message: error.message });
    }
});

// =============================================
// AGENT 01 - BRIEF (Mistral)
// =============================================
app.post('/webhook/agent-01', async (req, res) => {
    try {
        const { formData, prospectId } = req.body;
        console.log(`📝 [Agent 01 - Mistral] Brief pour ${prospectId}`);

        const brief = await callMistral(PROMPTS.AGENT_01, JSON.stringify(formData));

        let projectId = null;
        if (process.env.AIRTABLE_API_KEY) {
            const project = await createRecord('Projets', {
                'Client': [prospectId],
                'Brief': brief,
                'Statut': 'Briefing',
                'Date Création': new Date().toISOString()
            });
            projectId = project.id;
        }

        const client = await getRecord('Prospects', prospectId);
        if (client) {
            await sendWhatsApp(
                client.fields['Téléphone'],
                `📄 Merci ! Votre brief a été enregistré.\n\n✅ Notre équipe prépare votre devis dans les 24h.`
            );
        }

        res.json({ status: 'success', brief, projectId });

    } catch (error) {
        console.error('❌ Agent 01 Error:', error);
        res.status(500).json({ status: 'error', message: error.message });
    }
});

// =============================================
// AGENT 02 - DEVIS (Mistral)
// =============================================
app.post('/webhook/agent-02', async (req, res) => {
    try {
        const { projectId, brief } = req.body;
        console.log(`💰 [Agent 02 - Mistral] Devis ${projectId}`);

        const devis = await callMistralJSON(PROMPTS.AGENT_02, brief);

        if (process.env.AIRTABLE_API_KEY && projectId) {
            await updateRecord('Projets', projectId, {
                'Devis': devis.prix_ht,
                'TVA': devis.tva,
                'Total TTC': devis.total_ttc,
                'Statut': 'Devis Envoyé'
            });
        }

        const project = await getRecord('Projets', projectId);
        const client = await getRecord('Prospects', project?.fields?.Client?.[0]);

        if (client) {
            await sendWhatsApp(
                client.fields['Téléphone'],
                `📋 Votre devis est prêt !\n\n` +
                `Service : ${devis.service}\n` +
                `💰 Total : ${devis.total_ttc.toLocaleString()} FCFA TTC\n` +
                `📅 Délai : ${devis.duree}\n\n` +
                `✅ Répondez "OK devis" pour confirmer`
            );
        }

        res.json({ status: 'success', devis });

    } catch (error) {
        console.error('❌ Agent 02 Error:', error);
        res.status(500).json({ status: 'error', message: error.message });
    }
});

// =============================================
// AGENT 03 - CONCEPT (Dola pour complexe, Mistral pour simple)
// =============================================
app.post('/webhook/agent-03', async (req, res) => {
    try {
        const { brief, serviceType, clientName, clientPhone, projectId, entreprise } = req.body;
        console.log(`🎨 [Agent 03] ${serviceType} - ${clientName}`);

        // Déterminer la complexité
        const complexity = determineComplexity(brief, serviceType);
        const ai = getAIForTask('concept', complexity);
        console.log(`📊 Complexité: ${complexity} → IA: ${ai}`);

        let result, toolUsed;

        if (complexity === 'complex') {
            // ========== DOLA AI - COMPLEXE ==========
            toolUsed = 'Dola AI (Création complexe)';
            const content = await callDolaJSON(PROMPTS.AGENT_03_CONCEPT,
                `Service: ${serviceType}\nClient: ${clientName}\nBrief: ${brief}`
            );
            result = {
                type: 'complex',
                ai: 'dola',
                content: content,
                message: '🎨 Concept complexe généré par Dola AI'
            };
        } else {
            // ========== MISTRAL - SIMPLE ==========
            toolUsed = 'Mistral AI (Design simple)';
            const content = await callMistralJSON(PROMPTS.AGENT_03_SIMPLE,
                `Service: ${serviceType}\nClient: ${clientName}\nBrief: ${brief}`
            );
            const canvaUrl = generateCanvaAutofill(process.env.CANVA_TEMPLATE_FLYER || 'DAFxxxxx', {
                'nom_client': clientName,
                'nom_entreprise': entreprise || '718Digital',
                ...content
            });
            result = {
                type: 'simple',
                ai: 'mistral',
                url: canvaUrl,
                content: content,
                message: '📄 Design simple généré par Mistral'
            };
        }

        // Sauvegarde
        if (process.env.AIRTABLE_API_KEY && projectId) {
            await updateRecord('Projets', projectId, {
                'Statut': 'Concept Prêt',
                'Outil Utilisé': toolUsed,
                'Complexité': complexity,
                'Lien Livrable': result.url || JSON.stringify(result.content)
            });
        }

        // Envoi client
        await sendWhatsApp(
            clientPhone,
            `${result.message}\n\n` +
            `🔗 ${result.url || 'Concept généré'}\n\n` +
            `🛠️ Créé avec : ${toolUsed}\n` +
            `📋 Type : ${complexity === 'simple' ? 'Design simple' : 'Création complexe'}\n\n` +
            `✅ Validez en répondant "OK concept"`
        );

        // Notification interne
        if (INTERNAL_GROUP_ID) {
            await sendWhatsApp(
                INTERNAL_GROUP_ID,
                `🔔 NOUVEAU CONCEPT\n\nClient : ${clientName}\nService : ${serviceType}\nOutil : ${toolUsed}\nIA : ${ai}`
            );
        }

        res.json({ status: 'success', complexity, ai, result });

    } catch (error) {
        console.error('❌ Agent 03 Error:', error);
        res.status(500).json({ status: 'error', message: error.message });
    }
});

