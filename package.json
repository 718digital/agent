app.post('/webhook/agent-06', async (req, res) => {
    try {
        const { type, brief, clientName, clientPhone, projectId, entreprise } = req.body;
        console.log(`🛍️ [Agent 06] Shop: ${type} - ${clientName}`);

        const complexity = determineComplexity(brief, type);
        const ai = getAIForTask('shop', complexity);

