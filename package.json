            toolUsed = 'Dola AI (Shop complexe)';
            const content = await callDolaJSON(
                `Tu es un designer expert. Crée un concept pour ${type} en JSON:
                {
                    "nom": "Nom du produit",
                    "description": "Description détaillée",
                    "style": "Style visuel",
                    "couleurs": ["#couleur1", "#couleur2"],
                    "elements": ["élément1", "élément2"]
